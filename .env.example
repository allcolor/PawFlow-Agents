# PawFlow Environment Configuration
# Copy to .env and customize

# Security
# Preferred for production: 32 random bytes, base64-encoded.
# Example: python - <<'PY'
# import base64, os; print(base64.b64encode(os.urandom(32)).decode())
# PY
PAWFLOW_SECRET_KEY_B64=
# Dev fallback: password-derived key. Leave empty to use data/config/secret.key.
PAWFLOW_SECRET_KEY=
# Set PAWFLOW_PUBLIC_MODE=true or PAWFLOW_ENV=production to enforce prod boot checks.
PAWFLOW_PUBLIC_MODE=false
PAWFLOW_ENV=

# Docker Compose maps host port 9090 to the PawFlow listener by default.

# PostgreSQL (if using --profile postgres)
POSTGRES_PASSWORD=change-this-password
POSTGRES_PORT=5432
