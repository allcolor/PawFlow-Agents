# PawFlow Environment Configuration
# Copy to .env and customize

# Security
PAWFLOW_SECRET_KEY=change-this-to-a-random-string
PAWFLOW_CORS_ORIGINS=http://localhost:9090,http://localhost:8000

# Server
PAWFLOW_PORT=9090
PAWFLOW_AUTH_ENABLED=false

# Rate Limiting
PAWFLOW_RATE_LIMIT=true
PAWFLOW_RATE_LIMIT_MAX=100

# Request Size Limit (bytes, default 10MB)
PAWFLOW_MAX_BODY_SIZE=10485760

# PostgreSQL (if using --profile postgres)
POSTGRES_PASSWORD=change-this-password
POSTGRES_PORT=5432

# API URL (when running in API mode)
PAWFLOW_API_URL=http://localhost:8000
