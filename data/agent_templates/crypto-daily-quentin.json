{
  "id": "crypto-daily-quentin",
  "name": "Crypto Daily Summary",
  "version": "1.0.0",
  "tasks": {
    "httpTrigger": {
      "type": "httpReceiver",
      "parameters": {
        "path": "/crypto"
      }
    },
    "fetchPrices": {
      "type": "fetchHTTP",
      "parameters": {
        "url": "https://api.coingecko.com/api/v3/coins/markets?vs_currency=eur&ids=bitcoin,ethereum,binancecoin,palm-ai,spectre-ai",
        "method": "GET"
      }
    },
    "formatReport": {
      "type": "executeScript",
      "parameters": {
        "script": "import json\nimport datetime\n\ndata = json.loads(flow_file.content.decode())\nnow = datetime.datetime.now()\n\nreport = f\"📊 RÉSUMÉ CRYPTO - {now.strftime('%d/%m/%Y %H:%M')}\\n{'='*50}\\n\\n\"\n\nfor coin in data:\n    symbol = coin['symbol'].upper()\n    name = coin['name']\n    price = coin['current_price']\n    change = coin.get('price_change_percentage_24h', 0)\n    \n    if change >= 0:\n        change_str = f\"+{change:.2f}% 📈\"\n    else:\n        change_str = f\"{change:.2f}% 📉\"\n    \n    report += f\"{symbol} {name}: €{price:,.2f} ({change_str})\\n\"\n\nreport += f\"\\n{'='*50}\\nGénéré par PyFi2\"\n\nflow_file.content = report.encode('utf-8')\n"
      }
    },
    "sendEmail": {
      "type": "sendEmail",
      "parameters": {
        "smtp_host": "smtp.gmail.com",
        "smtp_port": "587",
        "use_tls": "true",
        "auth_type": "oauth2",
        "oauth2_provider": "gmail",
        "oauth2_client_id": "233903897030-e3sph4d1glr8ejpfu30vap8t8s9hllig.apps.googleusercontent.com",
        "oauth2_client_secret": "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",
        "oauth2_refresh_token": "***REMOVED_GOOGLE_OAUTH_REFRESH_TOKEN***",
        "from": "quentin.anciaux@allcolor.org",
        "to": "quentin.anciaux@allcolor.org",
        "subject": "📊 Résumé Crypto",
        "content": "${formatReport.content}",
        "content_type": "text/plain; charset=utf-8"
      }
    }
  },
  "connections": [
    {
      "source": "httpTrigger",
      "destination": "fetchPrices",
      "type": "success"
    },
    {
      "source": "fetchPrices",
      "destination": "formatReport",
      "type": "success"
    },
    {
      "source": "formatReport",
      "destination": "sendEmail",
      "type": "success"
    }
  ]
}