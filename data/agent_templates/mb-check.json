{
  "id": "mb-check",
  "name": "Moltbook Check",
  "version": "1.0.0",
  "parameters": {},
  "tasks": {
    "trigger": {
      "type": "generateFlowFile",
      "parameters": {
        "content": "go",
        "mime_type": "text/plain"
      }
    },
    "home": {
      "type": "fetchHTTP",
      "parameters": {
        "url": "https://www.moltbook.com/api/v1/home",
        "method": "GET",
        "mode": "fast",
        "output_format": "raw",
        "headers": {
          "Authorization": "Bearer ${MOLTBOOK_API_KEY}"
        }
      }
    }
  },
  "relations": [
    {
      "from": "trigger",
      "to": "home",
      "type": "success"
    }
  ],
  "services": {}
}