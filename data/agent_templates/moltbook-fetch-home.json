{
  "id": "moltbook-fetch-home",
  "name": "Moltbook Fetch Home",
  "version": "1.0.0",
  "parameters": {},
  "tasks": {
    "trigger": {
      "type": "generateFlowFile",
      "parameters": {
        "content": "start"
      }
    },
    "fetchHome": {
      "type": "fetchHTTP",
      "parameters": {
        "url": "https://www.moltbook.com/api/v1/home",
        "method": "GET",
        "mode": "fast",
        "output_format": "raw",
        "headers": {
          "Authorization": "Bearer ${MOLTBOOK_API_KEY}"
        }
      }
    },
    "logResult": {
      "type": "log",
      "parameters": {
        "level": "info",
        "message": "Home result: ${content}"
      }
    }
  },
  "relations": [
    {
      "from": "trigger",
      "to": "fetchHome",
      "type": "success"
    },
    {
      "from": "fetchHome",
      "to": "logResult",
      "type": "success"
    }
  ],
  "services": {}
}