{
  "_comment": "Pixazo model catalog. Each model declares one or more operations (text_to_image, edit_image, ...). Conventions: 'sync' = response carries the image URL directly; 'legacy_poll' = POST returns request_id, status is fetched by POSTing to poll_endpoint with the id; 'polling_url' = POST returns an absolute polling_url that we GET to fetch status (output.media_url[0]).",
  "models": {
    "sdxl": {
      "label": "SDXL (Stable Diffusion XL)",
      "category": "image",
      "operations": {
        "text_to_image": {
          "endpoint": "/getImage/v1/getSDXLImage",
          "convention": "sync",
          "url_field": "imageUrl",
          "params": {
            "width": "256-1024 (default 1024)",
            "height": "256-1024 (default 1024)",
            "num_steps": "1-20 (default 20)",
            "guidance_scale": "1-20 (default 5)",
            "negative_prompt": "text to avoid"
          }
        }
      }
    },
    "flux-dev": {
      "label": "Flux Dev (Black Forest Labs)",
      "category": "image",
      "operations": {
        "text_to_image": {
          "endpoint": "/flux-dev/v1/dev/textToImage",
          "poll_endpoint": "/flux-dev-polling/dev/getFluxDevStatus",
          "convention": "legacy_poll",
          "id_field": "requestId",
          "params": {
            "image_size": "e.g. 'landscape_4_3', 'square_hd', 'portrait_4_3'",
            "num_inference_steps": "1-50 (default 28)",
            "guidance_scale": "1-20 (default 3.5)",
            "output_format": "jpeg, png, webp",
            "num_images": "1-4"
          }
        }
      }
    },
    "nano-banana": {
      "label": "Nano Banana (Google) — original",
      "category": "image",
      "operations": {
        "text_to_image": {
          "endpoint": "/nano-banana/v1/nano-banana/generateTextToImageRequest",
          "poll_endpoint": "/nano-banana-polling/nano-banana/getStatus",
          "convention": "legacy_poll",
          "id_field": "request_id",
          "params": {
            "aspect_ratio": "1:1, 4:3, 3:2, 16:9, 9:16, 21:9, 2:3, 3:4, 4:5, 5:4",
            "output_format": "jpeg, png, webp",
            "num_images": "1-4"
          }
        },
        "edit_image": {
          "endpoint": "/nano-banana/v1/nano-banana/generateEditImageRequest",
          "convention": "polling_url",
          "id_field": "request_id",
          "input_field": "image_urls",
          "params": {
            "image_urls": "array of source image URLs",
            "num_images": "1-4 (default 1)",
            "output_format": "jpeg, png",
            "sync_mode": "boolean (default false)"
          }
        }
      }
    },
    "nano-banana-2": {
      "label": "Nano Banana 2 (Google)",
      "category": "image",
      "operations": {
        "text_to_image": {
          "endpoint": "/nano-banana-2/v1/nano-banana-2/generate",
          "convention": "polling_url",
          "id_field": "request_id",
          "params": {
            "aspect_ratio": "1:1, 1:4, 2:3, 3:2, 4:3, 16:9, 9:16",
            "resolution": "1K, 2K, 4K",
            "output_format": "jpg, png",
            "google_search": "boolean",
            "image_search": "boolean",
            "image_input": "array of image URLs (for image-conditioned gen)"
          }
        }
      }
    },
