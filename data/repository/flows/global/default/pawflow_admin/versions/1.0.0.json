{
  "id": "pawflow-admin",
  "name": "pawflow_admin",
  "version": "1.0.0",
  "description": "Native admin GUI for PawFlow. Deploy/undeploy independently. Visit /admin for the web interface.",
  "parameters": {
    "port": 9090
  },
  "services": {
    "http_listener": {
      "type": "httpListener",
      "parameters": {
        "host": "0.0.0.0",
        "port": 9090
      }
    },
    "auth": {
      "type": "authGateway",
      "parameters": {
        "providers": {
          "builtin": {
            "enabled": true
          }
        },
        "session_ttl": 86400
      }
    }
  },
  "tasks": {
    "http_in": {
      "type": "httpReceiver",
      "parameters": {
        "service_id": "http_listener",
        "routes": [
          {
            "method": "GET",
            "pattern": "/admin",
            "relationship": "GET:/admin"
          },
          {
            "method": "POST",
            "pattern": "/admin/api",
            "relationship": "POST:/admin/api"
          }
        ]
      }
    },
    "validate_auth": {
      "type": "validateSessionAuth",
      "parameters": {
        "cookie_name": "pawflow_token",
        "login_redirect": "/auth/login",
        "listener_service_id": "http_listener"
      }
    },
    "route_after_auth": {
      "type": "routeOnAttribute",
      "parameters": {
        "routes": {
          "admin_ui": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/admin"
          }
        },
        "default_relationship": "admin_api"
      }
    },
    "admin_ui": {
      "type": "serveAdminUI",
      "parameters": {
        "api_path": "/admin/api",
        "login_url": "/auth/login"
      }
    },
    "admin_api": {
      "type": "adminAction",
      "parameters": {}
    },
    "send_response": {
      "type": "handleHTTPResponse",
      "parameters": {
        "service_id": "http_listener",
        "content_type": "application/json"
      }
    }
  },
  "relations": [
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "GET:/admin"
    },
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "POST:/admin/api"
    },
    {
      "from": "validate_auth",
      "to": "route_after_auth",
      "type": "success"
    },
    {
      "from": "validate_auth",
      "to": "send_response",
      "type": "failure"
    },
    {
      "from": "route_after_auth",
      "to": "admin_ui",
      "type": "admin_ui"
    },
    {
      "from": "route_after_auth",
      "to": "admin_api",
      "type": "admin_api"
    },
    {
      "from": "admin_ui",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "admin_api",
      "to": "send_response",
      "type": "success"
    }
  ],
  "entries": [
    "http_in"
  ],
  "exits": [
    "send_response"
  ],
  "fqn": "default.pawflow_admin:1.0.0",
  "package": "default"
}