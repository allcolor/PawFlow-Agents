{
  "id": "pawflow-agent",
  "name": "pawflow_agent",
  "version": "1.0.0",
  "description": "LLM agent with SSE streaming, OAuth2 login, chat UI, multi-turn conversations, file generation, and per-tool permissions. Visit /chat for the web interface.",
  "parameters": {
    "conversation_ttl": 0,
    "oauth_provider": "google",
    "oauth_client_id": "",
    "oauth_client_secret": "",
    "oauth_redirect_uri": "http://localhost:9090/auth/callback",
    "oauth_default_role": "operator",
    "image_service": "${image_default_service}",
    "poll_interval": 30,
    "poll_recheck_delay": 7200,
    "max_workers": 32,
    "agent_max_instances": 20,
    "http_request_timeout": 600.0
  },
  "services": {
    "http_listener": {
      "type": "httpListener",
      "parameters": {
        "host": "0.0.0.0",
        "port": 9090,
        "request_timeout": "${http_request_timeout}"
      }
    },
    "oauth": {
      "type": "oauthProvider",
      "parameters": {
        "provider": "pawflow",
        "redirect_uri": "${oauth_redirect_uri}"
      }
    },
    "auth": {
      "type": "authGateway",
      "parameters": {
        "providers": {
          "builtin": {
            "enabled": true
          },
          "google": {
            "enabled": true,
            "client_id": "${oauth_client_id}",
            "client_secret": "${oauth_client_secret}"
          }
        },
        "session_ttl": 86400
      }
    }
  },
  "tasks": {
    "http_in": {
      "type": "httpReceiver",
      "parameters": {
        "service_id": "http_listener",
        "routes": [
          {
            "method": "POST",
            "pattern": "/api/agent",
            "relationship": "POST:/api/agent"
          },
          {
            "method": "GET",
            "pattern": "/api/agent/events",
            "relationship": "GET:/api/agent/events"
          },
          {
            "method": "GET",
            "pattern": "/chat",
            "relationship": "GET:/chat"
          },
          {
            "method": "GET",
            "pattern": "/chat/js/{path}",
            "relationship": "GET:/chat/js"
          },
          {
            "method": "GET",
            "pattern": "/files/{file_id}",
            "relationship": "GET:/files"
          },
          {
            "method": "GET",
            "pattern": "/files/{file_id}/{filename+}",
            "relationship": "GET:/files"
          },
          {
            "method": "GET",
            "pattern": "/fs/{service_name}/{rest+}",
            "relationship": "GET:/fs"
          },
          {
            "method": "GET",
            "pattern": "/auth/login",
            "relationship": "GET:/auth/login",
            "public": true
          },
          {
            "method": "GET",
            "pattern": "/auth/callback",
            "relationship": "GET:/auth/callback",
            "public": true
          },
          {
            "method": "POST",
            "pattern": "/auth/logout",
            "relationship": "POST:/auth/logout",
            "public": true
          }
        ]
      }
    },
    "relay_proxy": {
      "type": "serveRelayProxy",
      "parameters": {
        "service_id": "http_listener"
      }
    },
    "validate_auth": {
      "type": "validateSessionAuth",
      "parameters": {
        "cookie_name": "pawflow_token",
        "login_redirect": "/auth/login",
        "listener_service_id": "http_listener"
      }
    },
    "oauth_login": {
      "type": "oauthRedirect",
      "parameters": {
        "oauth_service_id": "oauth"
      }
    },
    "oauth_callback": {
      "type": "oauthCallback",
      "parameters": {
        "oauth_service_id": "oauth",
        "success_redirect": "/chat"
      }
    },
    "oauth_logout": {
      "type": "oauthLogout",
      "parameters": {
        "cookie_name": "pawflow_token",
        "redirect_to": "/chat"
      }
    },
    "agent": {
      "type": "agentLoop",
      "max_instances": "${agent_max_instances}",
      "parameters": {
        "system_prompt": "You are a helpful research assistant. You have access to tools for web search, web scraping, calculations, file reading, file creation, and autonomous continuation.\n\nWhen asked to research a topic:\n- Do multiple searches with different queries to get comprehensive results\n- Scrape relevant pages to get full content (use fetch)\n- Cross-reference information from multiple sources\n- If you need more research rounds, call schedule_continuation with a plan of what to do next — this will deliver your current findings to the user and automatically resume your work after a short pause\n- Synthesize findings into a well-structured response\n\nWhen creating files, provide the download URL to the user.\n\nIMPORTANT: For complex research tasks, use schedule_continuation to break your work into rounds. Each round: search/scrape, synthesize intermediate findings, then schedule_continuation if there's more to investigate.",
        "max_iterations": 200,
        "max_rounds": 5,
        "poll_interval": "${poll_interval}",
        "poll_recheck_delay": "${poll_recheck_delay}",
        "temperature": 0.7,
        "timeout": 600,
        "conversation_store": true,
        "conversation_ttl": "${conversation_ttl}",
        "file_base_url": "http://localhost:9090",
        "streaming": true,
        "image_service": "${image_service}"
      }
    },
    "agent_events": {
      "type": "agentSSEStream",
      "parameters": {
        "timeout": 600
      }
    },
    "chat_ui": {
      "type": "serveChatUI",
      "parameters": {
        "agent_path": "/api/agent",
        "sse_path": "/api/agent/events",
        "login_url": "/auth/login"
      }
    },
    "serve_file": {
      "type": "serveFile",
      "parameters": {}
    },
    "serve_relay_file": {
      "type": "serveRelayFile",
      "parameters": {}
    },
    "route_after_auth": {
      "type": "routeOnAttribute",
      "parameters": {
        "routes": {
          "chat": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/chat"
          },
          "sse": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/api/agent/events"
          },
          "files": {
            "attribute": "http.path",
            "operator": "matches_regex",
            "value": "^/files/"
          },
          "fs": {
            "attribute": "http.path",
            "operator": "matches_regex",
            "value": "^/fs/"
          },
          "chat_js": {
            "attribute": "http.path",
            "operator": "matches_regex",
            "value": "^/chat/js/"
          }
        },
        "default_relationship": "api"
      }
    },
    "format_response": {
      "type": "updateAttribute",
      "parameters": {
        "set": {
          "http.response.header.Content-Type": "application/json",
          "http.response.status": "200"
        }
      }
    },
    "send_response": {
      "type": "handleHTTPResponse",
      "parameters": {
        "service_id": "http_listener",
        "content_type": "application/json"
      }
    },
    "chat_assets": {
      "type": "serveAssets",
      "parameters": {
        "assets_prefix": "chat_ui",
        "cache_control": "public, max-age=31536000, immutable"
      }
    }
  },
  "relations": [
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "POST:/api/agent"
    },
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "GET:/chat"
    },
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "GET:/api/agent/events"
    },
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "GET:/files"
    },
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "GET:/fs"
    },
    {
      "from": "validate_auth",
      "to": "route_after_auth",
      "type": "success"
    },
    {
      "from": "validate_auth",
      "to": "send_response",
      "type": "failure"
    },
    {
      "from": "route_after_auth",
      "to": "agent",
      "type": "api"
    },
    {
      "from": "route_after_auth",
      "to": "chat_ui",
      "type": "chat"
    },
    {
      "from": "route_after_auth",
      "to": "agent_events",
      "type": "sse"
    },
    {
      "from": "route_after_auth",
      "to": "serve_file",
      "type": "files"
    },
    {
      "from": "route_after_auth",
      "to": "serve_relay_file",
      "type": "fs"
    },
    {
      "from": "http_in",
      "to": "oauth_login",
      "type": "GET:/auth/login"
    },
    {
      "from": "http_in",
      "to": "oauth_callback",
      "type": "GET:/auth/callback"
    },
    {
      "from": "http_in",
      "to": "oauth_logout",
      "type": "POST:/auth/logout"
    },
    {
      "from": "agent",
      "to": "format_response",
      "type": "success"
    },
    {
      "from": "format_response",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "agent_events",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "chat_ui",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "serve_file",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "serve_relay_file",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "oauth_login",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "oauth_callback",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "oauth_logout",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "route_after_auth",
      "to": "chat_assets",
      "type": "chat_js"
    },
    {
      "from": "chat_assets",
      "to": "send_response",
      "type": "success"
    },
    {
      "from": "http_in",
      "to": "validate_auth",
      "type": "GET:/chat/js"
    }
  ],
  "entries": [
    "http_in"
  ],
  "exits": [
    "send_response"
  ],
  "fqn": "default.pawflow_agent:1.0.0",
  "package": "default"
}