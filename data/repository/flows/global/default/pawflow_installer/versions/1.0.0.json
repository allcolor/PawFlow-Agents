{
  "id": "pawflow-installer",
  "name": "pawflow_installer",
  "version": "1.0.0",
  "description": "First-run bootstrap wizard for a new PawFlow server. Configures gateway, auth, LLM services, summarizer, variables, secrets, CLI credential pools, and final flow deployment.",
  "parameters": {
    "port": 9090,
    "bootstrap_gateway_key": "RoyBetty",
    "bootstrap_gateway_secret_ref": "privategateway.bootstrap",
    "private_gateway_service_id": "_bootstrap_private_gateway",
    "ssl_certfile": "data/system/ssl/bootstrap.crt",
    "ssl_keyfile": "data/system/ssl/bootstrap.key"
  },
  "services": {
    "http_listener": {
      "type": "httpListener",
      "parameters": {
        "host": "0.0.0.0",
        "port": "${port}",
        "request_timeout": 60.0,
        "ssl_certfile": "${ssl_certfile}",
        "ssl_keyfile": "${ssl_keyfile}",
        "private_gateway_service_id": "${private_gateway_service_id}"
      }
    }
  },
  "tasks": {
    "http_in": {
      "type": "httpReceiver",
      "parameters": {
        "service_id": "http_listener",
        "routes": [
          {
            "method": "GET",
            "pattern": "/install",
            "relationship": "GET:/install",
            "public": true
          },
          {
            "method": "GET",
            "pattern": "/install/api",
            "relationship": "GET:/install/api",
            "public": true
          },
          {
            "method": "POST",
            "pattern": "/install/api/finalize",
            "relationship": "POST:/install/api/finalize",
            "public": true
          },
          {
            "method": "POST",
            "pattern": "/install/api/llm-credential/prepare",
            "relationship": "POST:/install/api/llm-credential/prepare",
            "public": true
          },
          {
            "method": "POST",
            "pattern": "/install/api/llm-credential/paste",
            "relationship": "POST:/install/api/llm-credential/paste",
            "public": true
          },
          {
            "method": "POST",
            "pattern": "/install/api/llm-credential/server-login",
            "relationship": "POST:/install/api/llm-credential/server-login",
            "public": true
          },
          {
            "method": "POST",
            "pattern": "/install/api/llm-credential/server-login/status",
            "relationship": "POST:/install/api/llm-credential/server-login/status",
            "public": true
          },
          {
            "method": "POST",
            "pattern": "/install/api/llm-credential/server-login/cleanup",
            "relationship": "POST:/install/api/llm-credential/server-login/cleanup",
            "public": true
          }
        ]
      }
    },
    "route_install": {
      "type": "routeOnAttribute",
      "parameters": {
        "routes": {
          "api_status": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api"
          },
          "api_finalize": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api/finalize"
          },
          "llm_credential_prepare": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api/llm-credential/prepare"
          },
          "llm_credential_paste": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api/llm-credential/paste"
          },
          "llm_credential_server_login": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api/llm-credential/server-login"
          },
          "llm_credential_server_login_status": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api/llm-credential/server-login/status"
          },
          "llm_credential_server_login_cleanup": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api/llm-credential/server-login/cleanup"
          }
        },
        "default_relationship": "ui"
      }
    },
    "install_ui": {
      "type": "generateFlowFile",
      "parameters": {
        "content_type": "text/html; charset=utf-8",
        "content_file": "install.html"
      }
    },
    "install_api": {
      "type": "installBootstrap",
      "parameters": {}
    },
    "send_html": {
      "type": "handleHTTPResponse",
      "parameters": {
        "service_id": "http_listener",
        "content_type": "text/html; charset=utf-8"
      }
    },
    "send_json": {
      "type": "handleHTTPResponse",
      "parameters": {
        "service_id": "http_listener",
        "content_type": "application/json"
      }
    }
  },
  "relations": [
    {
      "from": "http_in",
      "to": "route_install",
      "type": "GET:/install"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "GET:/install/api"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "POST:/install/api/finalize"
    },
    {
      "from": "route_install",
      "to": "install_ui",
      "type": "ui"
    },
    {
      "from": "install_ui",
      "to": "send_html",
      "type": "success"
    },
    {
      "from": "install_api",
      "to": "send_json",
      "type": "success"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "api_status"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "api_finalize"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "POST:/install/api/llm-credential/prepare"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "POST:/install/api/llm-credential/paste"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "llm_credential_prepare"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "llm_credential_paste"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "POST:/install/api/llm-credential/server-login"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "llm_credential_server_login"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "POST:/install/api/llm-credential/server-login/status"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "llm_credential_server_login_status"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "POST:/install/api/llm-credential/server-login/cleanup"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "llm_credential_server_login_cleanup"
    }
  ],
  "entries": [
    "http_in"
  ],
  "exits": [
    "send_html",
    "send_json"
  ],
  "fqn": "default.pawflow_installer:1.0.0",
  "package": "default"
}
