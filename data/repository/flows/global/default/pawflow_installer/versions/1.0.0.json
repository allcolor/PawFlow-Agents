{
  "id": "pawflow-installer",
  "name": "pawflow_installer",
  "version": "1.0.0",
  "description": "First-run bootstrap wizard for a new PawFlow server. Configures gateway, auth, LLM services, summarizer, variables, secrets, CLI credential pools, and final flow deployment.",
  "parameters": {
    "port": 9090,
    "bootstrap_gateway_key": "RoyBetty",
    "ssl_certfile": "data/system/ssl/bootstrap.crt",
    "ssl_keyfile": "data/system/ssl/bootstrap.key"
  },
  "services": {
    "http_listener": {
      "type": "httpListener",
      "parameters": {
        "host": "0.0.0.0",
        "port": "${port}",
        "request_timeout": 60.0,
        "ssl_certfile": "${ssl_certfile}",
        "ssl_keyfile": "${ssl_keyfile}"
      }
    }
  },
  "tasks": {
    "http_in": {
      "type": "httpReceiver",
      "parameters": {
        "service_id": "http_listener",
        "routes": [
          {
            "method": "GET",
            "pattern": "/install",
            "relationship": "GET:/install",
            "public": true
          },
          {
            "method": "GET",
            "pattern": "/install/api",
            "relationship": "GET:/install/api",
            "public": true
          }
        ]
      }
    },
    "route_install": {
      "type": "routeOnAttribute",
      "parameters": {
        "routes": {
          "api": {
            "attribute": "http.path",
            "operator": "equals",
            "value": "/install/api"
          }
        },
        "default_relationship": "ui"
      }
    },
    "install_ui": {
      "type": "generateFlowFile",
      "parameters": {
        "content_type": "text/html; charset=utf-8",
        "content": "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>PawFlow Installer</title><style>body{margin:0;background:#0d1020;color:#e6edf7;font-family:Inter,system-ui,sans-serif}.wrap{max-width:920px;margin:0 auto;padding:48px 24px}.badge{display:inline-block;background:#1e8f4d;color:white;border-radius:6px;padding:4px 8px;font-size:12px}.panel{border:1px solid #26304a;background:#12172a;border-radius:8px;padding:24px;margin-top:24px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}.step{border:1px solid #26304a;border-radius:6px;padding:12px;background:#0f1424}.muted{color:#9aa7bd}.warn{color:#ffcf66}</style></head><body><main class=\"wrap\"><span class=\"badge\">bootstrap HTTPS</span><h1>PawFlow Installer</h1><p class=\"muted\">This first-run flow configures the server before the normal chat flows are deployed. Bootstrap starts with a self-signed TLS certificate.</p><section class=\"panel\"><h2>Required setup</h2><div class=\"grid\"><div class=\"step\">Server endpoint and certificates: upload/mount, Let&apos;s Encrypt, or self-signed</div><div class=\"step\">Private Gateway replacement key</div><div class=\"step\">Internal auth and Google OAuth</div><div class=\"step\">Admin user</div><div class=\"step\">LLM services</div><div class=\"step\">Summarizer service</div><div class=\"step\">Variables and secrets</div><div class=\"step\">CLI credential pools</div><div class=\"step\">Relay image profiles</div><div class=\"step\">Final smoke tests</div></div><p class=\"warn\">Initial gateway key: RoyBetty. Finalization must replace it.</p></section></main></body></html>"
      }
    },
    "install_api": {
      "type": "generateFlowFile",
      "parameters": {
        "content_type": "application/json",
        "content": "{\"install_complete\":false,\"flow\":\"PawFlow Installer\",\"tls\":{\"mode\":\"self_signed_bootstrap\",\"final_options\":[\"provided_certificate\",\"letsencrypt_acme\",\"self_signed\"]},\"client_relay_images\":{\"catalog\":\"config/relay_image_catalog.json\",\"generator\":\"scripts/generate-relay-image.py\",\"server_profile\":\"server-full\",\"default_client_profile\":\"client-minimal\",\"advanced_features\":true},\"steps\":[\"server\",\"certificates\",\"gateway\",\"auth\",\"admin\",\"llm_services\",\"summarizer_service\",\"variables\",\"secrets\",\"cli_credentials\",\"relay_image_profiles\",\"smoke_tests\",\"finalize\"]}"
      }
    },
    "send_html": {
      "type": "handleHTTPResponse",
      "parameters": {
        "service_id": "http_listener",
        "content_type": "text/html; charset=utf-8"
      }
    },
    "send_json": {
      "type": "handleHTTPResponse",
      "parameters": {
        "service_id": "http_listener",
        "content_type": "application/json"
      }
    }
  },
  "relations": [
    {
      "from": "http_in",
      "to": "route_install",
      "type": "GET:/install"
    },
    {
      "from": "http_in",
      "to": "route_install",
      "type": "GET:/install/api"
    },
    {
      "from": "route_install",
      "to": "install_ui",
      "type": "ui"
    },
    {
      "from": "route_install",
      "to": "install_api",
      "type": "api"
    },
    {
      "from": "install_ui",
      "to": "send_html",
      "type": "success"
    },
    {
      "from": "install_api",
      "to": "send_json",
      "type": "success"
    }
  ],
  "entries": ["http_in"],
  "exits": ["send_html", "send_json"],
  "fqn": "default.pawflow_installer:1.0.0",
  "package": "default"
}
