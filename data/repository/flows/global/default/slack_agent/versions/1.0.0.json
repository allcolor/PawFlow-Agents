{
  "id": "slack-agent",
  "name": "slack_agent",
  "version": "1.0.0",
  "description": "LLM agent accessible via Slack. Messages are processed by the agent and responses are sent back.",
  "parameters": {
    "llm_service": "${llm.default.service}",
    "slack_bot_token": "",
    "slack_app_token": "",
    "conversation_ttl": 0
  },
  "services": {
    "slack_bot": {
      "type": "slackBot",
      "parameters": {
        "bot_token": "${slack_bot_token}",
        "app_token": "${slack_app_token}",
        "mode": "socket"
      }
    }
  },
  "tasks": {
    "receive": {
      "type": "slackReceiver",
      "parameters": {
        "service_id": "slack_bot"
      }
    },
    "agent": {
      "type": "agentLoop",
      "parameters": {
        "llm_service": "${llm_service}",
        "system_prompt": "You are a helpful AI assistant on Slack. Be concise and helpful.",
        "conversation_attribute": "slack.channel_id",
        "conversation_ttl": "${conversation_ttl}",
        "max_iterations": 50
      }
    },
    "send_reply": {
      "type": "slackSend",
      "parameters": {
        "service_id": "slack_bot",
        "channel_id": "${slack.channel_id}"
      }
    }
  },
  "connections": [
    {
      "source": "receive",
      "target": "agent",
      "relationships": [
        "success"
      ]
    },
    {
      "source": "agent",
      "target": "send_reply",
      "relationships": [
        "success"
      ]
    }
  ],
  "fqn": "default.slack_agent:1.0.0",
  "package": "default"
}