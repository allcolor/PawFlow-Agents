{
  "id": "telegram-agent",
  "name": "telegram_agent",
  "version": "1.0.0",
  "description": "Telegram client for the shared PawFlow agent runtime. Messages are submitted through the same API contract used by webchat, PawCode, and VSCode.",
  "parameters": {
    "bot_token": "",
    "allowed_users": "",
    "target_agent": "",
    "agent_runtime_port": "pawflow_agent.agent_runtime_in",
    "agent_timeout": 600
  },
  "runtime_links": [
    {
      "from": "agent_client",
      "to": "${agent_runtime_port}",
      "type": "agentRuntime",
      "description": "Submit Telegram messages to the shared PawFlow agent runtime"
    }
  ],
  "services": {
    "telegram_bot": {
      "type": "telegramBot",
      "parameters": {
        "bot_token": "${bot_token}",
        "poll_timeout": 30,
        "allowed_users": "${allowed_users}"
      }
    }
  },
  "tasks": {
    "receive": {
      "type": "telegramReceiver",
      "parameters": {
        "service_id": "telegram_bot"
      }
    },
    "agent_client": {
      "type": "telegramAgentClient",
      "parameters": {
        "target_agent": "${target_agent}",
        "agent_runtime_port": "${agent_runtime_port}",
        "timeout": "${agent_timeout}",
        "create_conversation": false
      }
    },
    "send_reply": {
      "type": "telegramSend",
      "parameters": {
        "service_id": "telegram_bot",
        "chat_id": "${telegram.chat_id}",
        "parse_mode": "Markdown"
      }
    }
  },
  "fqn": "default.telegram_agent:1.0.0",
  "package": "default",
  "relations": [
    {
      "source": "receive",
      "target": "agent_client",
      "relationships": [
        "success"
      ]
    },
    {
      "source": "agent_client",
      "target": "send_reply",
      "relationships": [
        "success"
      ]
    }
  ]
}