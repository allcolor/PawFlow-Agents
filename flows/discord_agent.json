{
  "id": "discord-agent",
  "name": "Discord Agent",
  "version": "1.0.0",
  "description": "LLM agent accessible via Discord. Messages from Discord are processed by the agent and responses are sent back.",
  "parameters": {
    "llm_service": "${global.llm.default.service}",
    "bot_token": "",
    "guild_ids": "",
    "conversation_ttl": 0
  },
  "services": {
    "discord_bot": {
      "type": "discordBot",
      "parameters": {
        "bot_token": "${flow.parameters.bot_token}",
        "guild_ids": "${flow.parameters.guild_ids}"
      }
    }
  },
  "tasks": {
    "receive": {
      "type": "discordReceiver",
      "parameters": {
        "service_id": "discord_bot"
      }
    },
    "agent": {
      "type": "agentLoop",
      "parameters": {
        "llm_service": "${flow.parameters.llm_service}",
        "system_prompt": "You are a helpful AI assistant on Discord. Be concise and helpful.",
        "conversation_attribute": "discord.channel_id",
        "conversation_ttl": "${flow.parameters.conversation_ttl}",
        "max_iterations": 50
      }
    },
    "send_reply": {
      "type": "discordSend",
      "parameters": {
        "service_id": "discord_bot",
        "channel_id": "${discord.channel_id}"
      }
    }
  },
  "connections": [
    {
      "source": "receive",
      "target": "agent",
      "relationships": ["success"]
    },
    {
      "source": "agent",
      "target": "send_reply",
      "relationships": ["success"]
    }
  ]
}
