{
  "id": "http-hello-world",
  "name": "HTTP Hello World",
  "version": "1.0.2",
  "description": "Listens on /api/helloworld/{who} and responds with <h1>Hello {who}</h1>",
  "author": "",
  "created_at": null,
  "parameters": {},
  "entries": [],
  "exits": [],
  "tasks": {
    "http_in": {
      "type": "httpReceiver",
      "parameters": {
        "service_id": "http_listener",
        "routes": [
          {
            "method": "GET",
            "pattern": "/api/helloworld/{who}",
            "relationship": "GET:/api/helloworld/{who}"
          }
        ]
      }
    },
    "build_response": {
      "type": "updateAttribute",
      "parameters": {
        "set": {
          "http.response.header.Content-Type": "text/html; charset=utf-8",
          "http.response.status": "200"
        }
      }
    },
    "set_body": {
      "type": "replace_text",
      "parameters": {
        "search_pattern": ".*",
        "replacement": "<h1>Hello poupoule2 ${http.path.who}!</h1>",
        "regex": true,
        "case_sensitive": true,
        "multiline": false
      }
    },
    "send_response": {
      "type": "handleHTTPResponse",
      "parameters": {
        "service_id": "http_listener",
        "content_type": "text/html"
      }
    }
  },
  "services": {
    "http_listener": {
      "type": "httpListener",
      "parameters": {
        "host": "0.0.0.0",
        "port": 9090,
        "request_timeout": 30.0,
        "ssl_certfile": "",
        "ssl_keyfile": "",
        "ssl_keyfile_password": "",
        "ssl_service_id": ""
      },
      "config": {
        "host": "0.0.0.0",
        "port": 9090,
        "request_timeout": 30.0,
        "ssl_certfile": "",
        "ssl_keyfile": "",
        "ssl_keyfile_password": "",
        "ssl_service_id": ""
      }
    }
  },
  "groups": {},
  "relations": [
    {
      "from": "http_in",
      "to": "build_response",
      "type": "success"
    },
    {
      "from": "build_response",
      "to": "set_body",
      "type": "success"
    },
    {
      "from": "set_body",
      "to": "send_response",
      "type": "success"
    }
  ],
  "variables": {},
  "annotations": {}
}