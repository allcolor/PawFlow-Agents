{
  "id": "slack-agent",
  "name": "Slack Agent",
  "version": "1.0.0",
  "description": "LLM agent accessible via Slack. Messages are processed by the agent and responses are sent back.",
  "parameters": {
    "provider": "openai",
    "api_key": "",
    "base_url": "",
    "model": "",
    "slack_bot_token": "",
    "slack_app_token": "",
    "conversation_ttl": 0
  },
  "services": {
    "slack_bot": {
      "type": "slackBot",
      "parameters": {
        "bot_token": "${flow.parameters.slack_bot_token}",
        "app_token": "${flow.parameters.slack_app_token}",
        "mode": "socket"
      }
    }
  },
  "tasks": {
    "receive": {
      "type": "slackReceiver",
      "parameters": {
        "service_id": "slack_bot"
      }
    },
    "agent": {
      "type": "agentLoop",
      "parameters": {
        "provider": "${flow.parameters.provider}",
        "api_key": "${flow.parameters.api_key}",
        "base_url": "${flow.parameters.base_url}",
        "model": "${flow.parameters.model}",
        "system_prompt": "You are a helpful AI assistant on Slack. Be concise and helpful.",
        "conversation_attribute": "slack.channel_id",
        "conversation_ttl": "${flow.parameters.conversation_ttl}",
        "max_iterations": 50
      }
    },
    "send_reply": {
      "type": "slackSend",
      "parameters": {
        "service_id": "slack_bot",
        "channel_id": "${slack.channel_id}"
      }
    }
  },
  "connections": [
    {
      "source": "receive",
      "target": "agent",
      "relationships": ["success"]
    },
    {
      "source": "agent",
      "target": "send_reply",
      "relationships": ["success"]
    }
  ]
}
