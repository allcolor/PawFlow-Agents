import { CheckBox, ComboBox, LineEdit, ScrollView } from "std-widgets.slint";

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked();

    height: 34px;
    border-radius: 5px;
    border-width: 1px;
    border-color: !root.enabled ? #26334a : root.primary ? #3b92ff : root.danger ? #d74c63 : #385176;
    background: !root.enabled ? #121a2a :
        touch.pressed ? (root.primary ? #155fb5 : root.danger ? #842638 : #0e1a2d) :
        touch.has-hover ? (root.primary ? #2c83ef : root.danger ? #b93c52 : #1a2d4a) :
        (root.primary ? #1f73d8 : root.danger ? #9e2f42 : #13223a);

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    Text {
        text: root.text;
        color: root.enabled ? #f4f8ff : #64728b;
        font-size: 12px;
        font-weight: root.primary || root.danger ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> title;
    in property <string> action-text: "";
    callback action-clicked();

    height: 28px;
    HorizontalLayout {
        alignment: center;
        Text { text: root.title; color: #8fa4c8; font-size: 11px; font-weight: 800; }
        Rectangle { horizontal-stretch: 1; }
        if root.action-text != "" : ActionButton {
            width: 24px;
            height: 24px;
            text: root.action-text;
            clicked => { root.action-clicked(); }
        }
    }
}

component TreeItem inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <bool> selected: false;
    in property <bool> running: false;
    in property <int> level: 0;
    callback clicked();

    height: 38px;
    border-radius: 5px;
    border-width: 1px;
    border-color: root.selected ? #3479cc : item-touch.has-hover ? #263d5f : #0b1424;
    background: root.selected ? #142947 : item-touch.pressed ? #0d1a2c : item-touch.has-hover ? #101e33 : #0b1424;

    animate background { duration: 90ms; }
    animate border-color { duration: 90ms; }

    HorizontalLayout {
        padding-left: 8px + root.level * 14px;
        padding-right: 8px;
        spacing: 8px;
        alignment: center;

        Text { text: root.level > 0 ? "└" : ""; color: #566d91; font-size: 14px; }
        Rectangle {
            width: 7px;
            height: 7px;
            border-radius: 4px;
            background: root.running ? #22c55e : #71829e;
        }
        Text {
            text: root.title;
            color: #f2f6ff;
            font-size: 13px;
            font-weight: 650;
            overflow: elide;
        }
        Rectangle { horizontal-stretch: 1; }
        Text { text: root.meta; color: #88a0c4; font-size: 11px; overflow: elide; }
    }

    item-touch := TouchArea { clicked => { root.clicked(); } }
}

component FieldLabel inherits Text {
    color: #a8b9d8;
    font-size: 12px;
    font-weight: 600;
}

component PanelCard inherits Rectangle {
    background: #101b2d;
    border-color: #22395e;
    border-width: 1px;
    border-radius: 6px;
}

export component AppWindow inherits Window {
    title: "PawFlow Relay Desktop";
    preferred-width: 1180px;
    preferred-height: 760px;
    background: #050a13;

    in-out property <int> active-panel: 0;
    in-out property <string> status-text: "Ready";
    in-out property <string> summary-text: "Servers: 0 | Relays: 0 | Running: 0";
    in-out property <string> server-list: "No server configured";
    in-out property <string> relay-list: "No relay configured";
    in-out property <string> docker-list: "Docker images not loaded";
    in-out property <string> catalog-text: "Image catalog not loaded";
    in-out property <string> server-row-name: "No server";
    in-out property <string> server-row-meta: "add profile";
    in-out property <string> relay-row-name: "No relay";
    in-out property <string> relay-row-meta: "add relay";
    in-out property <string> logs: "[slint] Ready. Refresh to load PawFlow relay state.\n";

    in-out property <string> server-name: "prod";
    in-out property <string> server-url: "http://localhost:9090";
    in-out property <string> gateway-key: "";

    in-out property <string> relay-name: "pawflow";
    in-out property <string> relay-server: "prod";
    in-out property <string> workspace-path: "\\\\wsl$\\Ubuntu-24.04\\home\\qan\\Projets\\PawFlow";
    in-out property <string> relay-mode: "rw";
    in-out property <string> docker-image: "";
    in-out property <bool> allow-exec: true;
    in-out property <bool> allow-remote-desktop: true;
    in-out property <bool> allow-local-access: true;

    in-out property <string> image-name: "pawflow-relay-custom:latest";
    in-out property <string> image-profile: "client-minimal";
    in-out property <string> image-features: "";

    callback refresh-state();
    callback save-server();
    callback login-server();
    callback delete-server();
    callback save-relay();
    callback start-relay();
    callback stop-relay();
    callback delete-relay();
    callback build-image();
    callback clear-logs();
    callback browse-workspace-path();
    callback show-relay-panel();
    callback show-server-panel();
    callback show-image-panel();

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 260px;
            background: #0b1424;
            border-color: #203452;
            border-width: 1px;

            VerticalLayout {
                padding: 14px;
                spacing: 12px;

                HorizontalLayout {
                    spacing: 10px;
                    alignment: center;
                    Rectangle {
                        width: 32px;
                        height: 32px;
                        border-radius: 7px;
                        background: #1f73d8;
                        Text { text: "P"; color: white; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 1px;
                        Text { text: "PawFlow Relay"; color: #f2f6ff; font-size: 14px; font-weight: 800; }
                        Text { text: "Desktop relay manager"; color: #8fa4c8; font-size: 11px; }
                    }
                }

                Rectangle { height: 1px; background: #203452; }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-width: 232px;
                    Rectangle {
                        width: 232px;
                        height: 420px;
                        background: transparent;
                        VerticalLayout {
                            spacing: 8px;
                            SectionHeader { title: "SERVERS"; action-text: "+"; action-clicked => { root.show-server-panel(); } }
                            TreeItem {
                                title: root.server-row-name;
                                meta: root.server-row-meta;
                                selected: root.active-panel == 1;
                                level: 1;
                                clicked => { root.show-server-panel(); }
                            }
                            Text { text: root.server-list; color: #7184a5; font-size: 10px; wrap: word-wrap; }

                            SectionHeader { title: "RELAYS"; action-text: "+"; action-clicked => { root.show-relay-panel(); } }
                            TreeItem {
                                title: root.relay-row-name;
                                meta: root.relay-row-meta;
                                selected: root.active-panel == 0;
                                running: root.relay-row-meta == "running";
                                level: 1;
                                clicked => { root.show-relay-panel(); }
                            }
                            Text { text: root.relay-list; color: #7184a5; font-size: 10px; wrap: word-wrap; }

                            SectionHeader { title: "TOOLS"; }
                            TreeItem {
                                title: "Image builder";
                                meta: "docker";
                                selected: root.active-panel == 2;
                                level: 1;
                                clicked => { root.show-image-panel(); }
                            }
                        }
                    }
                }
            }
        }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            Rectangle {
                height: 82px;
                background: #0f192a;
                border-color: #203452;
                border-width: 1px;

                HorizontalLayout {
                    padding-left: 22px;
                    padding-right: 22px;
                    spacing: 16px;
                    alignment: center;

                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: root.active-panel == 0 ? root.relay-name : root.active-panel == 1 ? root.server-name : "Build Relay Image";
                            color: #f2f6ff;
                            font-size: 19px;
                            font-weight: 800;
                        }
                        Text {
                            text: root.active-panel == 0 ? root.workspace-path : root.active-panel == 1 ? root.server-url : root.catalog-text;
                            color: #8fa4c8;
                            font-size: 11px;
                            overflow: elide;
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text { text: root.summary-text; color: #b8c9e8; font-size: 12px; }
                    Rectangle {
                        height: 24px;
                        width: 72px;
                        border-radius: 12px;
                        background: root.status-text == "Ready" ? #143822 : #3a2b12;
                        Text { text: root.status-text; color: root.status-text == "Ready" ? #64d89d : #ffd27a; font-size: 11px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    ActionButton { width: 78px; text: "Refresh"; primary: true; clicked => { root.refresh-state(); } }
                }
            }

            Rectangle {
                background: #050a13;
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 18px;
                    spacing: 14px;

                    PanelCard {
                        visible: root.active-panel == 0;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;
                            Text { text: "Relay settings"; color: #f2f6ff; font-size: 18px; font-weight: 800; }
                            Text { text: "Workspace share, permissions, and relay process controls."; color: #8fa4c8; font-size: 12px; }

                            HorizontalLayout {
                                spacing: 12px;
                                VerticalLayout { spacing: 5px; FieldLabel { text: "Name"; } LineEdit { text <=> root.relay-name; } }
                                VerticalLayout { spacing: 5px; FieldLabel { text: "Server"; } LineEdit { text <=> root.relay-server; } }
                            }

                            VerticalLayout {
                                spacing: 5px;
                                FieldLabel { text: "Workspace path"; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    LineEdit { text <=> root.workspace-path; horizontal-stretch: 1; }
                                    ActionButton { width: 78px; text: "Browse"; clicked => { root.browse-workspace-path(); } }
                                }
                            }

                            HorizontalLayout {
                                spacing: 12px;
                                VerticalLayout { spacing: 5px; FieldLabel { text: "Mode"; } ComboBox { current-value <=> root.relay-mode; model: ["rw", "ro"]; } }
                                VerticalLayout { spacing: 5px; FieldLabel { text: "Docker image"; } LineEdit { text <=> root.docker-image; } }
                            }

                            HorizontalLayout {
                                spacing: 18px;
                                CheckBox { text: "Allow exec"; checked <=> root.allow-exec; }
                                CheckBox { text: "Remote desktop"; checked <=> root.allow-remote-desktop; }
                                CheckBox { text: "Local host access"; checked <=> root.allow-local-access; }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                ActionButton { width: 58px; text: "Save"; primary: true; clicked => { root.save-relay(); } }
                                ActionButton { width: 62px; text: "Start"; clicked => { root.start-relay(); } }
                                ActionButton { width: 58px; text: "Stop"; clicked => { root.stop-relay(); } }
                                ActionButton { width: 104px; text: "Delete Relay"; danger: true; clicked => { root.delete-relay(); } }
                            }

                            Rectangle { vertical-stretch: 1; }
                        }
                    }

                    PanelCard {
                        visible: root.active-panel == 1;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;
                            Text { text: "Server profile"; color: #f2f6ff; font-size: 18px; font-weight: 800; }
                            Text { text: "Connection details and login state for the selected PawFlow server."; color: #8fa4c8; font-size: 12px; }
                            FieldLabel { text: "Name"; }
                            LineEdit { text <=> root.server-name; }
                            FieldLabel { text: "URL"; }
                            LineEdit { text <=> root.server-url; }
                            FieldLabel { text: "Gateway key"; }
                            LineEdit { text <=> root.gateway-key; input-type: password; }
                            HorizontalLayout {
                                spacing: 8px;
                                ActionButton { width: 58px; text: "Save"; primary: true; clicked => { root.save-server(); } }
                                ActionButton { width: 112px; text: "Login / Status"; clicked => { root.login-server(); } }
                                ActionButton { width: 110px; text: "Delete Server"; danger: true; clicked => { root.delete-server(); } }
                            }
                            Rectangle { vertical-stretch: 1; }
                        }
                    }

                    PanelCard {
                        visible: root.active-panel == 2;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;
                            Text { text: "Relay image builder"; color: #f2f6ff; font-size: 18px; font-weight: 800; }
                            Text { text: root.catalog-text; color: #8fa4c8; font-size: 12px; wrap: word-wrap; }
                            HorizontalLayout {
                                spacing: 12px;
                                VerticalLayout { spacing: 5px; FieldLabel { text: "Image name"; } LineEdit { text <=> root.image-name; } }
                                VerticalLayout { spacing: 5px; FieldLabel { text: "Preset"; } ComboBox { current-value <=> root.image-profile; model: ["client-minimal", "client-full", "server-full", ""]; } }
                            }
                            FieldLabel { text: "Extra features (comma separated)"; }
                            LineEdit { text <=> root.image-features; }
                            ActionButton { width: 132px; text: "Build Image"; primary: true; clicked => { root.build-image(); } }
                            FieldLabel { text: "Local Docker images"; }
                            ScrollView {
                                vertical-stretch: 1;
                                Text { text: root.docker-list; color: #d8e5ff; font-family: "Consolas"; font-size: 11px; wrap: word-wrap; }
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 190px;
                background: #0b1424;
                border-color: #203452;
                border-width: 1px;

                VerticalLayout {
                    padding: 10px;
                    spacing: 7px;
                    HorizontalLayout {
                        Text { text: "Relay log"; color: #f2f6ff; font-size: 12px; font-weight: 800; }
                        Rectangle { horizontal-stretch: 1; }
                        Text { text: "stdout/stderr from relay and Docker commands"; color: #7184a5; font-size: 11px; }
                        ActionButton { width: 54px; height: 26px; text: "Clear"; primary: true; clicked => { root.clear-logs(); } }
                    }
                    ScrollView {
                        vertical-stretch: 1;
                        Text { text: root.logs; color: #d8e5ff; font-family: "Consolas"; font-size: 11px; wrap: word-wrap; }
                    }
                }
            }
        }
    }
}
