import { Button, CheckBox, LineEdit, ComboBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "PawFlow Relay Desktop";
    width: 1180px;
    height: 780px;
    background: #07111f;

    in-out property <string> status-text: "Ready";
    in-out property <string> summary-text: "Servers: 0 | Relays: 0 | Running: 0";
    in-out property <string> server-list: "No server configured";
    in-out property <string> relay-list: "No relay configured";
    in-out property <string> docker-list: "Docker images not loaded";
    in-out property <string> catalog-text: "Image catalog not loaded";
    in-out property <string> logs: "[slint] Ready. Refresh to load PawFlow relay state.\n";

    in-out property <string> server-name: "prod";
    in-out property <string> server-url: "http://localhost:9090";
    in-out property <string> gateway-key: "";

    in-out property <string> relay-name: "pawflow";
    in-out property <string> relay-server: "prod";
    in-out property <string> workspace-path: "\\\\wsl$\\Ubuntu-24.04\\home\\qan\\Projets\\PawFlow";
    in-out property <string> relay-mode: "rw";
    in-out property <string> docker-image: "";
    in-out property <bool> allow-exec: true;
    in-out property <bool> allow-remote-desktop: true;
    in-out property <bool> allow-local-access: true;

    in-out property <string> image-name: "pawflow-relay-custom:latest";
    in-out property <string> image-profile: "client-minimal";
    in-out property <string> image-features: "";

    callback refresh-state();
    callback save-server();
    callback login-server();
    callback delete-server();
    callback save-relay();
    callback start-relay();
    callback stop-relay();
    callback delete-relay();
    callback build-image();
    callback clear-logs();

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 58px;
            background: #0d1829;
            border-color: #203657;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 12px;
                alignment: center;

                Rectangle {
                    width: 34px;
                    height: 34px;
                    border-radius: 6px;
                    background: #2568c7;
                    Text { text: "P"; color: white; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }

                VerticalLayout {
                    spacing: 1px;
                    Text { text: "PawFlow Relay Desktop"; color: #f2f6ff; font-size: 18px; font-weight: 700; }
                    Text { text: "Native Slint manager for standalone client relays"; color: #9fb3d6; font-size: 12px; }
                }

                Rectangle { horizontal-stretch: 1; }

                Text { text: root.summary-text; color: #b9c9e8; font-size: 12px; }
                Rectangle { width: 1px; height: 28px; background: #243653; }
                Text { text: root.status-text; color: #64d89d; font-weight: 700; }
                Button { text: "Refresh"; clicked => { root.refresh-state(); } }
            }
        }

        HorizontalLayout {
            padding: 14px;
            spacing: 14px;

            Rectangle {
                width: 300px;
                background: #0b1625;
                border-color: #233754;
                border-width: 1px;
                border-radius: 6px;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    Text { text: "Servers"; color: #f2f6ff; font-size: 16px; font-weight: 700; }
                    Rectangle {
                        height: 130px;
                        background: #07111f;
                        border-color: #1d2f4c;
                        border-width: 1px;
                        border-radius: 4px;
                        clip: true;
                        Text { text: root.server-list; color: #d8e5ff; font-family: "Consolas"; font-size: 12px; wrap: word-wrap; }
                    }

                    Text { text: "Relays"; color: #f2f6ff; font-size: 16px; font-weight: 700; }
                    Rectangle {
                        height: 190px;
                        background: #07111f;
                        border-color: #1d2f4c;
                        border-width: 1px;
                        border-radius: 4px;
                        clip: true;
                        Text { text: root.relay-list; color: #d8e5ff; font-family: "Consolas"; font-size: 12px; wrap: word-wrap; }
                    }

                    Text { text: "Docker"; color: #f2f6ff; font-size: 16px; font-weight: 700; }
                    Rectangle {
                        background: #07111f;
                        border-color: #1d2f4c;
                        border-width: 1px;
                        border-radius: 4px;
                        clip: true;
                        Text { text: root.docker-list; color: #d8e5ff; font-family: "Consolas"; font-size: 12px; wrap: word-wrap; }
                    }
                }
            }

            VerticalLayout {
                spacing: 14px;

                HorizontalLayout {
                    spacing: 14px;

                    Rectangle {
                        width: 390px;
                        background: #101b2d;
                        border-color: #2a4164;
                        border-width: 1px;
                        border-radius: 6px;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;
                            Text { text: "Server profile"; color: #f2f6ff; font-size: 17px; font-weight: 700; }
                            Text { text: "Name"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.server-name; }
                            Text { text: "URL"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.server-url; }
                            Text { text: "Gateway key"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.gateway-key; input-type: password; }
                            HorizontalLayout {
                                spacing: 8px;
                                Button { text: "Save"; clicked => { root.save-server(); } }
                                Button { text: "Login / Status"; clicked => { root.login-server(); } }
                                Button { text: "Delete"; clicked => { root.delete-server(); } }
                            }
                        }
                    }

                    Rectangle {
                        background: #101b2d;
                        border-color: #2a4164;
                        border-width: 1px;
                        border-radius: 6px;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;
                            Text { text: "Relay image builder"; color: #f2f6ff; font-size: 17px; font-weight: 700; }
                            Text { text: root.catalog-text; color: #a8b9d8; font-size: 12px; wrap: word-wrap; }
                            Text { text: "Image name"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.image-name; }
                            Text { text: "Preset"; color: #a8b9d8; font-size: 12px; }
                            ComboBox { current-value <=> root.image-profile; model: ["client-minimal", "client-full", "server-full", ""]; }
                            Text { text: "Extra features (comma separated)"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.image-features; }
                            Button { text: "Build Docker image"; clicked => { root.build-image(); } }
                        }
                    }
                }

                Rectangle {
                    height: 285px;
                    background: #101b2d;
                    border-color: #2a4164;
                    border-width: 1px;
                    border-radius: 6px;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;
                        Text { text: "Relay workspace"; color: #f2f6ff; font-size: 17px; font-weight: 700; }

                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout { spacing: 5px; Text { text: "Name"; color: #a8b9d8; font-size: 12px; } LineEdit { text <=> root.relay-name; } }
                            VerticalLayout { spacing: 5px; Text { text: "Server"; color: #a8b9d8; font-size: 12px; } LineEdit { text <=> root.relay-server; } }
                            VerticalLayout { spacing: 5px; Text { text: "Mode"; color: #a8b9d8; font-size: 12px; } ComboBox { current-value <=> root.relay-mode; model: ["rw", "ro"]; } }
                        }

                        Text { text: "Path"; color: #a8b9d8; font-size: 12px; }
                        LineEdit { text <=> root.workspace-path; }

                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout { spacing: 5px; Text { text: "Docker image"; color: #a8b9d8; font-size: 12px; } LineEdit { text <=> root.docker-image; } }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            CheckBox { text: "Allow exec"; checked <=> root.allow-exec; }
                            CheckBox { text: "Remote desktop"; checked <=> root.allow-remote-desktop; }
                            CheckBox { text: "Local host access"; checked <=> root.allow-local-access; }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Button { text: "Save"; clicked => { root.save-relay(); } }
                            Button { text: "Start"; clicked => { root.start-relay(); } }
                            Button { text: "Stop"; clicked => { root.stop-relay(); } }
                            Button { text: "Delete"; clicked => { root.delete-relay(); } }
                        }
                    }
                }

                Rectangle {
                    background: #050b14;
                    border-color: #213452;
                    border-width: 1px;
                    border-radius: 6px;
                    clip: true;

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        HorizontalLayout {
                            Text { text: "Logs"; color: #f2f6ff; font-size: 16px; font-weight: 700; }
                            Rectangle { horizontal-stretch: 1; }
                            Button { text: "Clear"; clicked => { root.clear-logs(); } }
                        }
                        Text { text: root.logs; color: #d8e5ff; font-family: "Consolas"; font-size: 12px; wrap: word-wrap; }
                    }
                }
            }
        }
    }
}
