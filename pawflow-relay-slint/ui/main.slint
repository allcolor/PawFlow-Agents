import { Button, CheckBox, LineEdit, ComboBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "PawFlow Relay Desktop";
    width: 1320px;
    height: 820px;
    background: #050a13;

    in-out property <int> active-panel: 0;
    in-out property <string> status-text: "Ready";
    in-out property <string> summary-text: "Servers: 0 | Relays: 0 | Running: 0";
    in-out property <string> server-list: "No server configured";
    in-out property <string> relay-list: "No relay configured";
    in-out property <string> docker-list: "Docker images not loaded";
    in-out property <string> catalog-text: "Image catalog not loaded";
    in-out property <string> logs: "[slint] Ready. Refresh to load PawFlow relay state.\n";

    in-out property <string> server-name: "prod";
    in-out property <string> server-url: "http://localhost:9090";
    in-out property <string> gateway-key: "";

    in-out property <string> relay-name: "pawflow";
    in-out property <string> relay-server: "prod";
    in-out property <string> workspace-path: "\\\\wsl$\\Ubuntu-24.04\\home\\qan\\Projets\\PawFlow";
    in-out property <string> relay-mode: "rw";
    in-out property <string> docker-image: "";
    in-out property <bool> allow-exec: true;
    in-out property <bool> allow-remote-desktop: true;
    in-out property <bool> allow-local-access: true;

    in-out property <string> image-name: "pawflow-relay-custom:latest";
    in-out property <string> image-profile: "client-minimal";
    in-out property <string> image-features: "";

    callback refresh-state();
    callback save-server();
    callback login-server();
    callback delete-server();
    callback save-relay();
    callback start-relay();
    callback stop-relay();
    callback delete-relay();
    callback build-image();
    callback clear-logs();
    callback show-relay-panel();
    callback show-server-panel();
    callback show-image-panel();

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 258px;
            background: #0b1424;
            border-color: #213452;
            border-width: 1px;

            VerticalLayout {
                padding: 14px;
                spacing: 14px;

                HorizontalLayout {
                    spacing: 10px;
                    alignment: center;
                    Rectangle {
                        width: 34px;
                        height: 34px;
                        border-radius: 6px;
                        background: #2269d3;
                        Text { text: "P"; color: white; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 0px;
                        Text { text: "PawFlow Relay"; color: #f2f6ff; font-size: 16px; font-weight: 700; }
                        Text { text: "Client relay manager"; color: #8fa4c8; font-size: 12px; }
                    }
                }

                Rectangle { height: 1px; background: #1e314f; }

                Text { text: "SERVERS"; color: #8fa4c8; font-size: 12px; font-weight: 700; }
                Button { text: "Server profile"; clicked => { root.show-server-panel(); } }
                Rectangle {
                    height: 112px;
                    background: #081120;
                    border-color: #213452;
                    border-width: 1px;
                    border-radius: 4px;
                    clip: true;
                    Text { text: root.server-list; color: #dce8ff; font-family: "Consolas"; font-size: 11px; wrap: word-wrap; }
                }

                Text { text: "RELAYS"; color: #8fa4c8; font-size: 12px; font-weight: 700; }
                Button { text: "Relay settings"; clicked => { root.show-relay-panel(); } }
                Rectangle {
                    height: 138px;
                    background: #081120;
                    border-color: #213452;
                    border-width: 1px;
                    border-radius: 4px;
                    clip: true;
                    Text { text: root.relay-list; color: #dce8ff; font-family: "Consolas"; font-size: 11px; wrap: word-wrap; }
                }

                Text { text: "TOOLS"; color: #8fa4c8; font-size: 12px; font-weight: 700; }
                Button { text: "Build relay image"; clicked => { root.show-image-panel(); } }
                Rectangle {
                    vertical-stretch: 1;
                    background: #081120;
                    border-color: #213452;
                    border-width: 1px;
                    border-radius: 4px;
                    clip: true;
                    Text { text: root.docker-list; color: #dce8ff; font-family: "Consolas"; font-size: 11px; wrap: word-wrap; }
                }
            }
        }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            Rectangle {
                height: 72px;
                background: #0f192a;
                border-color: #213452;
                border-width: 1px;

                HorizontalLayout {
                    padding-left: 18px;
                    padding-right: 18px;
                    spacing: 16px;
                    alignment: center;

                    VerticalLayout {
                        spacing: 2px;
                        Text { text: root.active-panel == 0 ? root.relay-name : root.active-panel == 1 ? "Server profile" : "Relay image builder"; color: #f2f6ff; font-size: 20px; font-weight: 700; }
                        Text { text: root.active-panel == 0 ? root.workspace-path : root.active-panel == 1 ? root.server-url : root.catalog-text; color: #8fa4c8; font-size: 12px; }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text { text: root.summary-text; color: #b8c9e8; font-size: 12px; }
                    Text { text: root.status-text; color: #64d89d; font-weight: 700; }
                    Button { text: "Refresh"; clicked => { root.refresh-state(); } }
                }
            }

            Rectangle {
                background: #050a13;

                VerticalLayout {
                    padding: 18px;
                    spacing: 0px;

                    Rectangle {
                        visible: root.active-panel == 0;
                        width: 760px;
                        height: 360px;
                        background: #101b2d;
                        border-color: #2a4164;
                        border-width: 1px;
                        border-radius: 6px;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text { text: "Relay settings"; color: #f2f6ff; font-size: 18px; font-weight: 700; }
                            Text { text: "Edit the workspace share or control the relay process."; color: #8fa4c8; font-size: 12px; }

                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout { spacing: 5px; Text { text: "Name"; color: #a8b9d8; font-size: 12px; } LineEdit { text <=> root.relay-name; } }
                                VerticalLayout { spacing: 5px; Text { text: "Server"; color: #a8b9d8; font-size: 12px; } LineEdit { text <=> root.relay-server; } }
                            }

                            Text { text: "Path"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.workspace-path; }

                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout { spacing: 5px; Text { text: "Mode"; color: #a8b9d8; font-size: 12px; } ComboBox { current-value <=> root.relay-mode; model: ["rw", "ro"]; } }
                                VerticalLayout { spacing: 5px; Text { text: "Docker image"; color: #a8b9d8; font-size: 12px; } LineEdit { text <=> root.docker-image; } }
                            }

                            HorizontalLayout {
                                spacing: 16px;
                                CheckBox { text: "Allow exec"; checked <=> root.allow-exec; }
                                CheckBox { text: "Remote desktop"; checked <=> root.allow-remote-desktop; }
                                CheckBox { text: "Local host access"; checked <=> root.allow-local-access; }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                Button { text: "Save"; clicked => { root.save-relay(); } }
                                Button { text: "Start"; clicked => { root.start-relay(); } }
                                Button { text: "Stop"; clicked => { root.stop-relay(); } }
                                Button { text: "Delete Relay"; clicked => { root.delete-relay(); } }
                            }
                        }
                    }

                    Rectangle {
                        visible: root.active-panel == 1;
                        width: 620px;
                        height: 330px;
                        background: #101b2d;
                        border-color: #2a4164;
                        border-width: 1px;
                        border-radius: 6px;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text { text: "Server profile"; color: #f2f6ff; font-size: 18px; font-weight: 700; }
                            Text { text: "Edit connection details, login, or remove this server profile."; color: #8fa4c8; font-size: 12px; }
                            Text { text: "Name"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.server-name; }
                            Text { text: "URL"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.server-url; }
                            Text { text: "Gateway key"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.gateway-key; input-type: password; }
                            HorizontalLayout {
                                spacing: 8px;
                                Button { text: "Save"; clicked => { root.save-server(); } }
                                Button { text: "Login / Status"; clicked => { root.login-server(); } }
                                Button { text: "Delete Server"; clicked => { root.delete-server(); } }
                            }
                        }
                    }

                    Rectangle {
                        visible: root.active-panel == 2;
                        width: 760px;
                        height: 330px;
                        background: #101b2d;
                        border-color: #2a4164;
                        border-width: 1px;
                        border-radius: 6px;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text { text: "Relay image builder"; color: #f2f6ff; font-size: 18px; font-weight: 700; }
                            Text { text: root.catalog-text; color: #8fa4c8; font-size: 12px; wrap: word-wrap; }
                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout { spacing: 5px; Text { text: "Image name"; color: #a8b9d8; font-size: 12px; } LineEdit { text <=> root.image-name; } }
                                VerticalLayout { spacing: 5px; Text { text: "Preset"; color: #a8b9d8; font-size: 12px; } ComboBox { current-value <=> root.image-profile; model: ["client-minimal", "client-full", "server-full", ""]; } }
                            }
                            Text { text: "Extra features (comma separated)"; color: #a8b9d8; font-size: 12px; }
                            LineEdit { text <=> root.image-features; }
                            Button { text: "Build Docker image"; clicked => { root.build-image(); } }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }
                }
            }

            Rectangle {
                height: 150px;
                background: #0b1424;
                border-color: #213452;
                border-width: 1px;
                clip: true;

                VerticalLayout {
                    padding: 10px;
                    spacing: 6px;
                    HorizontalLayout {
                        Text { text: "Logs"; color: #f2f6ff; font-size: 13px; font-weight: 700; }
                        Rectangle { horizontal-stretch: 1; }
                        Button { text: "Clear"; clicked => { root.clear-logs(); } }
                    }
                    Text { text: root.logs; color: #d8e5ff; font-family: "Consolas"; font-size: 11px; wrap: word-wrap; }
                }
            }
        }
    }
}
